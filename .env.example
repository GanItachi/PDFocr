# --- OBLIGATOIRE (OCR + chat Gemini) ---
# Clé gratuite : https://aistudio.google.com/apikey (sans carte bancaire)
GEMINI_API_KEY=

# --- OPTIONNEL (autres IA au choix dans l'interface) ---
# Groq (gratuit) : https://console.groq.com/keys
GROQ_API_KEY=
# Mistral La Plateforme (palier "Experiment" gratuit) : https://console.mistral.ai/
MISTRAL_API_KEY=
# OpenRouter (modèles suffixés ":free") : https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- OPTIONNEL : forcer des modèles précis (sinon valeurs par défaut du code) ---
# GEMINI_OCR_MODEL=gemini-2.5-flash
# GEMINI_OCR_FALLBACK_MODEL=gemini-2.5-flash-lite
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile
# MISTRAL_CHAT_MODEL=mistral-small-latest
# OPENROUTER_CHAT_MODEL=deepseek/deepseek-r1:free
